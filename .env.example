# Schwab Developer Portal app credentials (Trader API - Individual)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=

# Aliases accepted by the CLI (same precedence tier as SCHWAB_*)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# OAuth redirect URI registered with your Schwab app (default: https://127.0.0.1:8182)
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182

# Optional override for token storage directory (default: platform config dir)
# SCHWAB_TOKEN_DIR=

# Options agent — OpenRouter LLM advisor (when llm.enabled in rules/*.yaml)
# OPENROUTER_API_KEY=

# schwab-trader — optional API tokens for sources.feeds (auth.token_env in rules YAML)
# POLYGON_API_KEY=

# Options agent — Telegram notifications (when notify.telegram.enabled)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# CLI behavior
# SCHWAB_MODE=agent          # agent | human
# SCHWAB_OUTPUT=json         # pretty | json | md
# NO_COLOR=1
